# Sao chép file này thành .env.properties và điền khóa từ tài khoản eSMS.
# Không commit .env.properties lên Git.
SMS_PROVIDER=esms
ESMS_API_KEY=YOUR_ESMS_API_KEY
ESMS_SECRET_KEY=YOUR_ESMS_SECRET_KEY

# SmsType=8 gửi OTP bằng đầu số cố định, không cần Brandname.
ESMS_SMS_TYPE=8

# Dùng true để kiểm tra request mà không gửi và không tính phí.
ESMS_SANDBOX=true

# Chỉ đổi thành true sau khi eSMS xác nhận mẫu OTP đã được duyệt.
ESMS_TEMPLATE_READY=false
SMS_OTP_TEMPLATE=SANKYUU - Ma OTP cua ban la {OTP}. Ma co hieu luc trong 5 phut.
