// Hàm xử lý sự kiện khi người dùng bấm nút Đăng nhập
async function handleLogin(usernameInput, passwordInput) {
    const url = '/api/login';

    // Đóng gói tham số thành một đối tượng
    const loginPayload = {
        username: usernameInput,
        password: passwordInput
    };

    try {
        // Gửi request POST, truyền dữ liệu qua Request Body
        const response = await fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            // Chuyển đổi đối tượng JavaScript thành chuỗi JSON
            body: JSON.stringify(loginPayload)
        });

        if (response.ok) {
            console.log("Đăng nhập thành công");
            // Xử lý chuyển hướng trang hoặc lưu Token tại đây
        } else {
            console.error("Sai tài khoản hoặc mật khẩu");
        }
    } catch (error) {
        console.error("Lỗi kết nối máy chủ: ", error);
    }
}